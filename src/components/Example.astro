---
interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<div class="example">
  <p class="label">例{title ? `（${title}）` : ''}</p>
  <div class="body">
    <slot />
  </div>
</div>

<style>
  .example {
    margin: 1.5rem 0;
    padding: 1rem 1.25rem;
    border-left: 3px solid var(--color-accent);
  }

  .label {
    margin: 0 0 0.4rem;
    font-weight: bold;
    font-family: var(--font-sans);
  }

  .body {
    margin: 0;
  }

  .body :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
