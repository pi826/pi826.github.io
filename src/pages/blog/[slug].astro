---
import { getCollection, render } from 'astro:content';
import BlogPostLayout from '../../layouts/BlogPostLayout.astro';
import Theorem from '../../components/Theorem.astro';
import Definition from '../../components/Definition.astro';
import Proof from '../../components/Proof.astro';

export async function getStaticPaths() {
  const posts = await getCollection(
    'blog',
    (post) => !post.data.draft || !import.meta.env.PROD,
  );
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BlogPostLayout
  title={post.data.title}
  date={post.data.date}
  tags={post.data.tags}
  description={post.data.description}
>
  <Content components={{ Theorem, Definition, Proof }} />
</BlogPostLayout>
